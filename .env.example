# Copy this file to .env and fill in real values
# Run: cp .env.example .env
#
# This file lists EVERY variable that docker-compose.yml reads.
# Generate secrets with: python -c "import secrets; print(secrets.token_hex(32))"

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USER=webai_user
DB_PASSWORD=change_me_please

# ── Bridge secrets ────────────────────────────────────────────────────────────
SECRET_KEY=generate_a_long_random_string_here
COOKIE_ENCRYPTION_KEY=generate_another_long_random_string_here

# Shared between bridge and webai — MUST be identical in both services
WEBAI_INTERNAL_KEY=generate_a_third_long_random_string_here

# ── NATS ──────────────────────────────────────────────────────────────────────
# Token must match on all sides: this NATS server, the bridge, and pizzasys.
# Defaults to "localdev" for local dev — use a strong value in production.
NATS_TOKEN=localdev
# Override NATS URL. Default=nats://nats:4222 (webai-nats container).
# Shared NATS example: NATS_URL=nats://nats.lcportal.cloud:4222
NATS_URL=
# Set NATS_TLS=true when connecting to a NATS server that requires TLS
NATS_TLS=false
NATS_USER=
NATS_PASS=
NATS_AUTH_STREAM=AUTH_EVENTS
NATS_AUTH_DURABLE=WEBAI_BRIDGE_AUTH_CONSUMER
# DEV_MODE=1 uses auth.testing.v1.* subjects, DEV_MODE=0 uses auth.v1.*
DEV_MODE=0

# ── CORS (extra browser origins allowed to call the bridge) ──────────────────
# Localhost is always allowed. In production add the PUBLIC frontend URL(s),
# comma-separated. Example:
#   CORS_ORIGINS=http://2.25.70.122:3000,https://app.yourdomain.com
CORS_ORIGINS=

# ── Auth server (pizzasys) ────────────────────────────────────────────────────
# Local dev (pizzasys on host):  http://host-gateway:8001
# Production:                     https://your-pizzasys-domain.com
AUTH_SERVER_BASE_URL=http://host-gateway:8001
# Service-client token from pizzasys (POST /api/v1/service-clients, shown once)
AUTH_SERVER_CALL_TOKEN=
# Optional legacy direct login URL
LARAVEL_AUTH_URL=

# ── Ollama (embeddings; runs on the host, reached via host-gateway) ───────────
OLLAMA_URL=http://host-gateway:11434
OLLAMA_MODEL=nomic-embed-text

# ── Frontend (BUILD-TIME — baked into the bundle; rebuild on change) ──────────
# The public URL of the bridge API (through nginx in production)
VITE_API_URL=http://localhost:8000
# The public URL of pizzasys auth
VITE_AUTH_URL=http://localhost:8001
